# YPAT 后端 environment template — development
# 复制为 .env 后修改；本文件可提交到 Git

SPRING_PROFILES_ACTIVE=dev

# === MySQL（开发默认本地） ===
YPAT_MYSQL_URL=jdbc:mysql://localhost:3306/ypat?characterEncoding=utf8&useSSL=false
YPAT_MYSQL_USERNAME=ypat_dev
YPAT_MYSQL_PASSWORD=<placeholder>
YPAT_DB_NAME=ypat
YPAT_DB_USERNAME=ypat_dev
YPAT_DB_PASSWORD=<placeholder>

# === Redis（开发默认无密码） ===
YPAT_REDIS_HOST=localhost
YPAT_REDIS_PORT=6379
YPAT_REDIS_PASSWORD=

# === Eureka（开发默认本地） ===
YPAT_EUREKA_DEFAULT_ZONE=http://localhost:8761/eureka/

# === JWT / SSO ===
YPAT_SSO_JWT_SIGNING_KEY=development-only-sso-jwt-key-change-me
YPAT_SSO_CLIENT0_SECRET=development-only-sso-client0-change-me
YPAT_SSO_CLIENT1_SECRET=development-only-sso-client1-change-me

# === 微信小程序（开发可空） ===
YPAT_WX_APP_ID=
YPAT_WX_APP_SECRET=

# === 微信公众号（开发可空） ===
YPAT_WX_PUB_APP_ID=
YPAT_WX_PUB_APP_SECRET=

# === 微信支付（开发可空） ===
YPAT_WX_MCH_ID=
YPAT_WX_PAY_KEY=

# === 百度 OCR（开发可空） ===
YPAT_BD_IDCARD_AK=
YPAT_BD_IDCARD_SK=
YPAT_BD_IDMATCH_AK=
YPAT_BD_IDMATCH_SK=
YPAT_WEB_BD_OCR_AK=
YPAT_WEB_BD_OCR_SK=
YPAT_BD_APP_KEY=
YPAT_BD_APP_SECRET=

# === 短信（开发可开 mock） ===
YPAT_SMS_MOCK_ENABLED=true
YPAT_SMS_MOCK_PHONE=18888888888
YPAT_SMS_MOCK_CODE=888888

# === FastDFS ===
YPAT_FDFS_PUBLIC_BASE_URL=http://localhost:8888
YPAT_FDFS_TRACKER_SERVERS=ypat-fastdfs-tracker:22122

# === Storage Provider / Tencent COS ===
YPAT_STORAGE_PROVIDER=cos
YPAT_COS_SECRET_ID=
YPAT_COS_SECRET_KEY=
YPAT_COS_REGION=ap-beijing
YPAT_COS_BUCKET=
YPAT_COS_PUBLIC_BASE_URL=https://imgs.panghu.work
YPAT_COS_ENV_PREFIX=dev

# === Docker compose 端口（开发环境） ===
YPAT_LOCAL_MYSQL_HOST=127.0.0.1
YPAT_LOCAL_MYSQL_PORT=3307
YPAT_LOCAL_MYSQL_ROOT_PASSWORD=ypat_dev_password_change_me
YPAT_LOCAL_MYSQL_USER=root
YPAT_LOCAL_MYSQL_DATABASE=ypat
YPAT_LOCAL_REDIS_PORT=6379
YPAT_LOCAL_REDIS_PASSWORD=ypat_dev_redis_password_change_me
YPAT_LOCAL_EUREKA_PORT=8761
YPAT_LOCAL_WAP_PORT=8081
YPAT_LOCAL_WEB_PORT=8082
YPAT_LOCAL_RESTAPI_PORT=9081
YPAT_FASTDFS_IMAGE=ygqygq2/fastdfs-nginx@sha256:076ee9c1ab73f16d81b28f6f8e0405e67446994f9541020115d5e2f546cbde48
YPAT_FASTDFS_TRACKER_DATA_DIR=./backend/dev/fastdfs/tracker_data
YPAT_FASTDFS_STORAGE_DATA_DIR=./backend/dev/fastdfs/storage_data

# === 日志 ===
YPAT_LOG_DIR=/logs

# === RabbitMQ（可选） ===
YPAT_RABBITMQ_URL=amqp://localhost:5672
YPAT_RABBITMQ_USERNAME=guest
YPAT_RABBITMQ_PASSWORD=guest
