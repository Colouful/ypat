# 环境配置示例
# 复制此文件为 .env.development / .env.production

# 应用环境
VITE_APP_ENV=development

# API 基础地址（development(开发环境) 默认走本地 Docker nginx(网关)，production(生产环境) 必须使用 HTTPS 域名）
VITE_API_BASE_URL=http://localhost:8080/api

# 图片基础地址（注意末尾带 /）
VITE_IMAGE_BASE_URL=https://fastdfs.panghu.work/

# 图片上传 API 基础地址（可选；本地开发默认走本地后端）
VITE_IMAGE_UPLOAD_API_BASE_URL=http://localhost:8081

# --- production 环境示例 ---
# VITE_APP_ENV=production
# VITE_API_BASE_URL=https://api.<正式域名>
# VITE_IMAGE_BASE_URL=https://static.<正式域名>/

# 微信小程序 AppID (不要填写真实值到代码仓库)
VITE_WX_APPID=

# 百度小程序 AppID
VITE_BD_APPID=
