# 数据库
YPAT_MYSQL_URL=jdbc:mysql://<staging-mysql-host>:3306/ypat?characterEncoding=utf8&useSSL=false
YPAT_MYSQL_USERNAME=<staging-user>
YPAT_MYSQL_PASSWORD=<staging-password>

# Redis
YPAT_REDIS_HOST=<staging-redis-host>
YPAT_REDIS_PORT=6379
YPAT_REDIS_PASSWORD=<staging-redis-password>

# 服务发现
YPAT_EUREKA_DEFAULT_ZONE=http://<staging-eureka-host>:8761/eureka/

# JWT / OAuth
YPAT_WAP_JWT_SECRET=<staging-wap-jwt-secret>
YPAT_WEB_JWT_SECRET=<staging-web-jwt-secret>
YPAT_SSO_JWT_SIGNING_KEY=<staging-sso-jwt-signing-key>
YPAT_SSO_CLIENT0_SECRET=<staging-sso-client0-secret>
YPAT_SSO_CLIENT1_SECRET=<staging-sso-client1-secret>

# 微信与支付
WECHAT_APP_ID=<staging-wechat-app-id>
WECHAT_APP_SECRET=<staging-wechat-app-secret>
WECHAT_PAY_MCH_ID=<staging-wechat-pay-mch-id>
WECHAT_PAY_KEY=<staging-wechat-pay-key>

# 短信
SMS_ACCESS_KEY=<staging-sms-access-key>
SMS_SECRET_KEY=<staging-sms-secret-key>
ALIYUN_SMS_ENABLED=false

# 文件服务
YPAT_FASTDFS_HTTP_SECRET_KEY=<staging-fastdfs-secret-if-enabled>

# 本地 Docker 开发专用，预发部署不应使用该变量。
YPAT_LOCAL_MYSQL_ROOT_PASSWORD=<local-dev-password>
