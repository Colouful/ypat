# YPAT 后端 environment template — staging
# 复制为 .env 后修改；本文件可提交到 Git
# 实际部署由 CI / 部署平台注入真实值，禁止 commit 真实密钥

SPRING_PROFILES_ACTIVE=pre

# === MySQL ===
YPAT_MYSQL_URL=jdbc:mysql://ypat-staging-mysql:3306/ypat?characterEncoding=utf8&useSSL=false
YPAT_MYSQL_USERNAME=ypat_app
YPAT_MYSQL_PASSWORD=<placeholder>
YPAT_DB_NAME=ypat
YPAT_DB_USERNAME=ypat_app
YPAT_DB_PASSWORD=<placeholder>
YPAT_LOCAL_MYSQL_PORT=3306
YPAT_LOCAL_MYSQL_ROOT_PASSWORD=<placeholder>

# === Redis ===
YPAT_REDIS_HOST=ypat-staging-redis
YPAT_REDIS_PORT=6379
YPAT_REDIS_PASSWORD=<placeholder>
YPAT_LOCAL_REDIS_PORT=6379
YPAT_LOCAL_REDIS_PASSWORD=<placeholder>

# === Eureka ===
YPAT_EUREKA_DEFAULT_ZONE=http://ypat-staging-eureka:8761/eureka/
YPAT_LOCAL_EUREKA_PORT=8761

# === JWT / SSO ===
YPAT_SSO_JWT_SIGNING_KEY=<placeholder>
YPAT_SSO_CLIENT0_SECRET=<placeholder>
YPAT_SSO_CLIENT1_SECRET=<placeholder>

# === 微信小程序 ===
YPAT_WX_APP_ID=<placeholder>
YPAT_WX_APP_SECRET=<placeholder>

# === 微信公众号 ===
YPAT_WX_PUB_APP_ID=<placeholder>
YPAT_WX_PUB_APP_SECRET=<placeholder>

# === 微信支付 ===
YPAT_WX_MCH_ID=<placeholder>
YPAT_WX_PAY_KEY=<placeholder>
YPAT_WX_PAY_MODE=PUBLIC_KEY
YPAT_WX_H5_APP_ID=<placeholder>
YPAT_WX_MCH_SERIAL_NO=<placeholder>
YPAT_WX_MCH_PRIVATE_KEY_PATH=/run/secrets/wechat-pay/apiclient_key.pem
YPAT_WX_API_V3_KEY=<placeholder>
YPAT_WX_PAY_PUBLIC_KEY_ID=<placeholder>
YPAT_WX_PAY_PUBLIC_KEY_PATH=/run/secrets/wechat-pay/pub_key.pem
YPAT_WX_NOTIFY_URL=https://panghu.work/api/payment/wechat/notify
YPAT_WX_H5_SCENE_INFO=
YPAT_WX_PAY_SECRET_DIR=./docker/secrets/wechat-pay

# === 百度 OCR / AI ===
YPAT_BD_IDCARD_AK=<placeholder>
YPAT_BD_IDCARD_SK=<placeholder>
YPAT_BD_IDMATCH_AK=<placeholder>
YPAT_BD_IDMATCH_SK=<placeholder>
YPAT_WEB_BD_OCR_AK=<placeholder>
YPAT_WEB_BD_OCR_SK=<placeholder>
YPAT_BD_APP_KEY=<placeholder>
YPAT_BD_APP_SECRET=<placeholder>

# === 短信（staging 禁止 Mock，必须使用真实网关或第三方）===
YPAT_SMS_MOCK_ENABLED=false
YPAT_SMS_MOCK_PHONE=
YPAT_SMS_MOCK_CODE=

# === FastDFS ===
YPAT_FDFS_PUBLIC_BASE_URL=https://panghu.work/files
YPAT_FDFS_TRACKER_SERVERS=ypat-staging-fastdfs-tracker:22122

# === Storage Provider / Tencent COS ===
YPAT_STORAGE_PROVIDER=cos
YPAT_COS_SECRET_ID=
YPAT_COS_SECRET_KEY=
YPAT_COS_REGION=ap-beijing
YPAT_COS_BUCKET=
YPAT_COS_PUBLIC_BASE_URL=https://imgs.panghu.work
YPAT_COS_ENV_PREFIX=pre

YPAT_FASTDFS_IMAGE=ygqygq2/fastdfs-nginx@sha256:076ee9c1ab73f16d81b28f6f8e0405e67446994f9541020115d5e2f546cbde48
YPAT_FASTDFS_TRACKER_DATA_DIR=/opt/ypat-data/staging/fastdfs/tracker
YPAT_FASTDFS_STORAGE_DATA_DIR=/opt/ypat-data/staging/fastdfs/storage

# === 日志 ===
YPAT_LOG_DIR=/logs

# === 服务端口 ===
YPAT_LOCAL_WAP_PORT=8081
YPAT_LOCAL_WEB_PORT=8082
YPAT_LOCAL_RESTAPI_PORT=9081

# === RabbitMQ（可选）===
YPAT_RABBITMQ_URL=amqp://ypat-staging-rabbitmq:5672
YPAT_RABBITMQ_USERNAME=ypat
YPAT_RABBITMQ_PASSWORD=<placeholder>
