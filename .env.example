# YPAT 预发/生产环境配置模板
# 复制为 .env 并修改密码

# === MySQL（Docker 容器内） ===
YPAT_LOCAL_MYSQL_PORT=3306
YPAT_LOCAL_MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# === Redis（Docker 容器内） ===
YPAT_LOCAL_REDIS_PORT=6379
YPAT_LOCAL_REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# === Eureka（仅本地访问） ===
YPAT_LOCAL_EUREKA_PORT=8761

# === WAP ===
YPAT_LOCAL_WAP_PORT=8081

# === 微信小程序登录 ===
# AppID 需要和 91pai-master/manifest.json、project.config.json 保持一致。
YPAT_WX_APP_ID=wx37ee5a90fc7ecb21
# AppSecret 是敏感密钥，只能从微信公众平台获取；不要提交真实值。
YPAT_WX_APP_SECRET=CHANGE_ME_FROM_WECHAT_MP_CONSOLE

# === 微信支付 v3（小程序/JSAPI/H5） ===
# PUBLIC_KEY 表示微信支付公钥模式：回调验签使用微信支付公钥，而不是平台证书。
YPAT_WX_PAY_MODE=PUBLIC_KEY
YPAT_WX_H5_APP_ID=${YPAT_WX_APP_ID}
YPAT_WX_MCH_ID=CHANGE_ME_FROM_WECHAT_PAY_MCH_ID
YPAT_WX_MCH_SERIAL_NO=CHANGE_ME_FROM_MERCHANT_API_CERT_SERIAL_NO
YPAT_WX_MCH_PRIVATE_KEY_PATH=/run/secrets/wechat-pay/apiclient_key.pem
YPAT_WX_API_V3_KEY=CHANGE_ME_FROM_WECHAT_PAY_API_V3_KEY
YPAT_WX_PAY_PUBLIC_KEY_ID=CHANGE_ME_FROM_WECHAT_PAY_PUBLIC_KEY_ID
YPAT_WX_PAY_PUBLIC_KEY_PATH=/run/secrets/wechat-pay/pub_key.pem
YPAT_WX_NOTIFY_URL=https://your-domain.example/payment/notify
# H5 支付上线时按微信支付要求配置域名、应用名、包名等；小程序支付可留空。
YPAT_WX_H5_SCENE_INFO=
YPAT_WX_PAY_SECRET_DIR=./docker/secrets/wechat-pay

# === System Web ===
YPAT_LOCAL_WEB_PORT=8082

# === FastDFS 公开 URL（仅兼容历史文件） ===
YPAT_FDFS_PUBLIC_BASE_URL=https://panghu.work/files

# === Storage Provider / Tencent COS ===
YPAT_STORAGE_PROVIDER=cos
YPAT_COS_SECRET_ID=
YPAT_COS_SECRET_KEY=
YPAT_COS_REGION=ap-beijing
YPAT_COS_BUCKET=
YPAT_COS_PUBLIC_BASE_URL=https://imgs.panghu.work
YPAT_COS_ENV_PREFIX=pre

# === FastDFS 镜像（固定 digest） ===
# 获取方式：scripts/deploy/get-fastdfs-digest.sh
YPAT_FASTDFS_IMAGE=ygqygq2/fastdfs-nginx@sha256:CHANGE_ME_GET_FROM_SERVER

# === FastDFS 数据目录 ===
YPAT_FASTDFS_TRACKER_DATA_DIR=/opt/ypat-data/fastdfs/tracker
YPAT_FASTDFS_STORAGE_DATA_DIR=/opt/ypat-data/fastdfs/storage

# === MySQL 业务数据库（应用账号） ===
# 应用账号，不得是 root；root 仅用于 mysql 容器初始化。
YPAT_DB_NAME=ypat
YPAT_DB_USERNAME=ypat_app
YPAT_DB_PASSWORD=CHANGE_ME_STRONG_APP_PASSWORD
YPAT_MYSQL_URL=jdbc:mysql://mysql:3306/ypat?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai

# === Eureka ===
YPAT_EUREKA_DEFAULT_ZONE=http://eureka:8761/eureka/

# === FastDFS Tracker 地址（应用使用） ===
YPAT_FDFS_TRACKER_SERVERS=fastdfs-tracker:22122

# === SSO JWT 签名密钥（必须替换） ===
YPAT_SSO_JWT_SIGNING_KEY=CHANGE_ME_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# === 镜像源（可选，国内加速） ===
# REGISTRY_MIRROR=https://mirror.ccs.tencentyun.com
