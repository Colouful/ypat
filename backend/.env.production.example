# YPAT 后端 environment template — production
# 复制为 .env 后修改；本文件可提交到 Git
# 严禁使用 panghu.work / 82.156.14.216 等 staging 串用地址
# 严禁使用 CHANGE_ME / <placeholder> / TODO 等占位符 — 部署前必须注入真实值
# 所有敏感值由部署平台（CI / Vault / KMS）注入，禁止 commit

SPRING_PROFILES_ACTIVE=pro

# === MySQL（最小权限业务账号，非 root）===
YPAT_MYSQL_URL=jdbc:mysql://ypat-production-mysql:3306/ypat?characterEncoding=utf8&useSSL=true&requireSSL=true&verifyServerCertificate=true
YPAT_MYSQL_USERNAME=ypat_app
YPAT_MYSQL_PASSWORD=
YPAT_DB_NAME=ypat
YPAT_DB_USERNAME=ypat_app
YPAT_DB_PASSWORD=
# root 仅用于运维初始化/备份/迁移
YPAT_LOCAL_MYSQL_PORT=3306
YPAT_LOCAL_MYSQL_ROOT_PASSWORD=

# === Redis（必须密码）===
YPAT_REDIS_HOST=ypat-production-redis
YPAT_REDIS_PORT=6379
YPAT_REDIS_PASSWORD=

# === Eureka ===
YPAT_EUREKA_DEFAULT_ZONE=https://ypat-production-eureka:8761/eureka/
YPAT_LOCAL_EUREKA_PORT=8761

# === JWT / SSO（强制轮换 90d）===
YPAT_SSO_JWT_SIGNING_KEY=
YPAT_SSO_CLIENT0_SECRET=
YPAT_SSO_CLIENT1_SECRET=

# === 微信小程序 ===
YPAT_WX_APP_ID=
YPAT_WX_APP_SECRET=

# === 微信公众号 ===
YPAT_WX_PUB_APP_ID=
YPAT_WX_PUB_APP_SECRET=

# === 微信支付 ===
YPAT_WX_MCH_ID=
YPAT_WX_PAY_KEY=

# === 百度 OCR / AI ===
YPAT_BD_IDCARD_AK=
YPAT_BD_IDCARD_SK=
YPAT_BD_IDMATCH_AK=
YPAT_BD_IDMATCH_SK=
YPAT_WEB_BD_OCR_AK=
YPAT_WEB_BD_OCR_SK=
YPAT_BD_APP_KEY=
YPAT_BD_APP_SECRET=

# === 短信（production 必须使用真实网关，禁止 Mock）===
YPAT_SMS_MOCK_ENABLED=false
YPAT_SMS_MOCK_PHONE=
YPAT_SMS_MOCK_CODE=

# === FastDFS（生产必须由部署平台注入，不允许占位符）===
YPAT_FDFS_PUBLIC_BASE_URL=
YPAT_FDFS_TRACKER_SERVERS=
YPAT_FASTDFS_IMAGE=ygqygq2/fastdfs-nginx@sha256:076ee9c1ab73f16d81b28f6f8e0405e67446994f9541020115d5e2f546cbde48
YPAT_FASTDFS_TRACKER_DATA_DIR=/opt/ypat-data/production/fastdfs/tracker
YPAT_FASTDFS_STORAGE_DATA_DIR=/opt/ypat-data/production/fastdfs/storage

# === 日志 ===
YPAT_LOG_DIR=/logs

# === 服务端口 ===
YPAT_LOCAL_WAP_PORT=8081
YPAT_LOCAL_WEB_PORT=8082
YPAT_LOCAL_RESTAPI_PORT=9081

# === RabbitMQ（可选）===
YPAT_RABBITMQ_URL=amqp://ypat-production-rabbitmq:5672
YPAT_RABBITMQ_USERNAME=ypat
YPAT_RABBITMQ_PASSWORD=