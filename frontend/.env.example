# 环境配置示例
# 复制此文件为 .env.development / .env.production

# 应用环境
VITE_APP_ENV=development

# API 基础地址（dev 用 localhost，pro 用线上 IP）
VITE_API_BASE_URL=http://localhost:8088

# 图片基础地址（注意末尾带 /）
VITE_IMAGE_BASE_URL=http://localhost:8088/

# --- production 环境示例 ---
# VITE_APP_ENV=production
# VITE_API_BASE_URL=http://82.156.14.216:8088
# VITE_IMAGE_BASE_URL=http://82.156.14.216:8088/

# 微信小程序 AppID (不要填写真实值到代码仓库)
VITE_WX_APPID=

# 百度小程序 AppID
VITE_BD_APPID=
