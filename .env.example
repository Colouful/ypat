# YPAT 预发/生产环境配置模板
# 复制为 .env 并修改密码

# === MySQL（Docker 容器内） ===
YPAT_LOCAL_MYSQL_PORT=3306
YPAT_LOCAL_MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# === Redis（Docker 容器内） ===
YPAT_LOCAL_REDIS_PORT=6379
YPAT_LOCAL_REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# === Eureka（仅本地访问） ===
YPAT_LOCAL_EUREKA_PORT=8761

# === WAP ===
YPAT_LOCAL_WAP_PORT=8081

# === System Web ===
YPAT_LOCAL_WEB_PORT=8082

# === FastDFS 公开 URL ===
YPAT_FDFS_PUBLIC_BASE_URL=https://panghu.work/files

# === FastDFS 镜像（固定 digest） ===
# 获取方式：scripts/deploy/get-fastdfs-digest.sh
YPAT_FASTDFS_IMAGE=ygqygq2/fastdfs-nginx@sha256:CHANGE_ME_GET_FROM_SERVER

# === FastDFS 数据目录 ===
YPAT_FASTDFS_TRACKER_DATA_DIR=/opt/ypat-data/fastdfs/tracker
YPAT_FASTDFS_STORAGE_DATA_DIR=/opt/ypat-data/fastdfs/storage

# === MySQL 业务数据库（应用账号） ===
# 应用账号，不得是 root；root 仅用于 mysql 容器初始化。
YPAT_DB_NAME=ypat
YPAT_DB_USERNAME=ypat_app
YPAT_DB_PASSWORD=CHANGE_ME_STRONG_APP_PASSWORD
YPAT_MYSQL_URL=jdbc:mysql://mysql:3306/ypat?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai

# === Eureka ===
YPAT_EUREKA_DEFAULT_ZONE=http://eureka:8761/eureka/

# === FastDFS Tracker 地址（应用使用） ===
YPAT_FDFS_TRACKER_SERVERS=fastdfs-tracker:22122

# === SSO JWT 签名密钥（必须替换） ===
YPAT_SSO_JWT_SIGNING_KEY=CHANGE_ME_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# === 镜像源（可选，国内加速） ===
# REGISTRY_MIRROR=https://mirror.ccs.tencentyun.com