{
  "name": "ypat-uniapp",
  "version": "1.0.0",
  "description": "YPAT 爱去拍 - 摄影约拍撮合平台",
  "scripts": {
    "dev:h5": "uni",
    "dev:h5:staging": "uni --mode staging",
    "dev:h5:production": "uni --mode production",
    "dev:mp-weixin": "uni -p mp-weixin",
    "dev:mp-weixin:staging": "uni -p mp-weixin --mode staging",
    "dev:mp-weixin:production": "uni -p mp-weixin --mode production",
    "dev:mp-baidu": "uni -p mp-baidu",
    "dev:app": "uni -p app",
    "build:h5": "uni build",
    "build:h5:staging": "uni build --mode staging",
    "build:h5:production": "uni build --mode production",
    "build:mp-weixin": "uni build -p mp-weixin",
    "build:mp-weixin:staging": "uni build -p mp-weixin --mode staging",
    "build:mp-weixin:production": "uni build -p mp-weixin --mode production",
    "build:mp-baidu": "uni build -p mp-baidu",
    "build:app": "uni build -p app",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint src --ext .ts,.vue --quiet",
    "lint:all": "eslint src --ext .ts,.vue",
    "lint:fix": "eslint src --ext .ts,.vue --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,scss}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "env:validate:development": "node scripts/config/validate-frontend-env.mjs development",
    "env:validate:staging": "node scripts/config/validate-frontend-env.mjs staging",
    "env:validate:production": "node scripts/config/validate-frontend-env.mjs production",
    "check:development": "pnpm run env:validate:development && pnpm run type-check && pnpm run lint && pnpm run test && pnpm run build:h5",
    "check:staging": "pnpm run env:validate:staging && pnpm run type-check && pnpm run lint && pnpm run test && pnpm run build:h5:staging && pnpm run build:mp-weixin:staging",
    "check:production": "pnpm run env:validate:production && pnpm run type-check && pnpm run lint && pnpm run test && pnpm run build:h5:production && pnpm run build:mp-weixin:production",
    "build:all:staging": "pnpm run build:h5:staging && pnpm run build:mp-weixin:staging",
    "build:all:production": "pnpm run build:h5:production && pnpm run build:mp-weixin:production",
    "check": "pnpm run check:development"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4080420251103001",
    "@dcloudio/uni-app-harmony": "3.0.0-4080420251103001",
    "@dcloudio/uni-app-plus": "3.0.0-4080420251103001",
    "@dcloudio/uni-components": "3.0.0-4080420251103001",
    "@dcloudio/uni-h5": "3.0.0-4080420251103001",
    "@dcloudio/uni-mp-baidu": "3.0.0-4080420251103001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4080420251103001",
    "@dcloudio/uni-quickapp-webview": "3.0.0-4080420251103001",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^3.2.1",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "3.0.0-4080420251103001",
    "@dcloudio/uni-cli-shared": "3.0.0-4080420251103001",
    "@dcloudio/uni-stacktracey": "3.0.0-4080420251103001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4080420251103001",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/runtime-core": "^3.4.21",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.1.3",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.26.0",
    "prettier": "^3.2.5",
    "sass": "^1.77.0",
    "typescript": "~5.4.5",
    "vite": "5.2.8",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.0.0"
  }
}
