{
  "name": "ypat-admin",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "YPAT 后台管理系统 - Vue3 + TypeScript + Element Plus",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:staging": "vue-tsc --noEmit && vite build --mode staging",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .ts,.vue --fix",
    "lint:check": "eslint . --ext .ts,.vue",
    "stylelint": "stylelint \"src/**/*.{css,scss,vue}\" --fix",
    "stylelint:check": "stylelint \"src/**/*.{css,scss,vue}\"",
    "format": "prettier --write \"src/**/*.{ts,vue,scss,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "pinia": "^2.3.0",
    "element-plus": "^2.9.1",
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.7.9",
    "nprogress": "^0.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "typescript": "~5.7.2",
    "vite": "^6.0.5",
    "vue-tsc": "^2.1.10",
    "vitest": "^2.1.8",
    "jsdom": "^25.0.1",
    "sass": "^1.83.0",
    "unplugin-auto-import": "^0.19.0",
    "unplugin-vue-components": "^0.28.0",
    "eslint": "^9.17.0",
    "@eslint/js": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "typescript-eslint": "^8.19.0",
    "prettier": "^3.4.2",
    "stylelint": "^16.12.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "stylelint-config-recommended-vue": "^1.5.0",
    "@types/nprogress": "^0.2.3",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "meow": "^13.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@parcel/watcher", "esbuild", "meow", "vue-demi"]
  }
}
