# backend-v2 runtime Dockerfile.
#
# Build context is the repo root (.).
# The Spring Boot fat jar is produced on the host by
# `mvn package` and dropped at backend-v2/app.jar (see
# scripts/docker-build-backend-v2.sh) before this build runs.
# We don't reach Maven Central from inside Docker.

FROM eclipse-temurin:21-jre-alpine
WORKDIR /app

COPY backend-v2/app.jar /app/app.jar

ENV SPRING_PROFILES_ACTIVE=docker

EXPOSE 8082
ENTRYPOINT ["java", "-jar", "/app/app.jar"]